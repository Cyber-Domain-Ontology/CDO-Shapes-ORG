<http://example.org/kb>
	a owl:Ontology ;
	rdfs:comment "This knowledge base instantiates each of the shape-reviewed classes and properties, so SHACL shapes can be exercised for the reviewed ontology."@en ;
	owl:imports <http://example.org/shapes/sh-org> ;
	.

kb:ChangeEvent-1a6c6f6b-3307-4ca5-a994-9b0a401ceec1
	a org:ChangeEvent ;
	rdfs:seeAlso sh-org:ChangeEvent-disjointWith-Organization-shape ;
	.

kb:Membership-1d9fdc4a-edfb-48bd-8c4e-dcf57f5eb3fd
	a org:Membership ;
	rdfs:seeAlso sh-org:Membership-disjointWith-Organization-shape ;
	.

